#!/bin/bash

# gparted-launch — GParted drive selector wrapper for Linux systems.
# Select one drive; GParted opens on that device only.
# MIT License 2026 Musqz

set -euo pipefail

# ── translations ─────────────────────────────────────────────────────────────────

case "${LANGUAGE:-$LANG}" in
    nl*)
        TITLE_ERR="GParted starter"
        TITLE_DLG="GParted — schijf selecteren"
        TEXT_DEP="<b>Ontbrekende afhankelijkheid:</b> <tt>%s</tt>\n\nInstalleer het eerst:\n<tt>sudo pacman -S %s</tt>"
        TEXT_NODEV="Geen blokschijven gevonden."
        TEXT_DLG="<b>GParted partitie-editor</b>\n\nSelecteer een schijf en klik op <i>Starten</i>.\nVoor een andere schijf, sluit GParted en start dit opnieuw."
        BTN_CANCEL="annuleren:1"
        BTN_LAUNCH="GParted starten:0"
        ;;
    pl*)
        TITLE_ERR="Uruchamiacz GParted"
        TITLE_DLG="GParted — wybierz dysk"
        TEXT_DEP="<b>Brakujący zależny program:</b> <tt>%s</tt>\n\nZainstaluj go najpierw:\n<tt>sudo pacman -S %s</tt>"
        TEXT_NODEV="Nie znaleziono urządzeń blokowych."
        TEXT_DLG="<b>Edytor partycji GParted</b>\n\nWybierz dysk i kliknij <i>Uruchom</i>.\nAby wybrać inny dysk, zamknij GParted i uruchom ten skrypt ponownie."
        BTN_CANCEL="anuluj:1"
        BTN_LAUNCH="Uruchom GParted:0"
        ;;
    es*)
        TITLE_ERR="Lanzador de GParted"
        TITLE_DLG="GParted — seleccionar unidad"
        TEXT_DEP="<b>Dependencia faltante:</b> <tt>%s</tt>\n\nInstálala primero:\n<tt>sudo pacman -S %s</tt>"
        TEXT_NODEV="No se encontraron dispositivos de bloque."
        TEXT_DLG="<b>Editor de particiones GParted</b>\n\nSelecciona una unidad y haz clic en <i>Iniciar</i>.\nPara una unidad diferente, cierra GParted y ejecuta esto de nuevo."
        BTN_CANCEL="cancelar:1"
        BTN_LAUNCH="Iniciar GParted:0"
        ;;
    *)
        TITLE_ERR="GParted launcher"
        TITLE_DLG="GParted — select drive"
        TEXT_DEP="<b>Missing dependency:</b> <tt>%s</tt>\n\nInstall it first:\n<tt>sudo pacman -S %s</tt>"
        TEXT_NODEV="No block devices found."
        TEXT_DLG="<b>GParted partition editor</b>\n\nSelect a drive and click <i>Launch</i>.\nFor a different drive, close GParted and run this again."
        BTN_CANCEL="cancel:1"
        BTN_LAUNCH="Launch GParted:0"
        ;;
esac

# ── dependencies ─────────────────────────────────────────────────────────────────

_need() {
    if ! command -v "$1" &>/dev/null; then
        yad --center --title="$TITLE_ERR" \
            --image=dialog-error \
            --text="$(printf "$TEXT_DEP" "$1" "$2")" \
            --button="OK:0" 2>/dev/null \
        || notify-send -i dialog-error "$TITLE_ERR" "'$1' is not installed."
        exit 1
    fi
}

_need gparted  gparted
_need yad      yad
_need lsblk    util-linux

# ── icon ─────────────────────────────────────────────────────────────────────────

GPICON=""
for candidate in \
    /usr/share/pixmaps/gparted.png \
    /usr/share/icons/hicolor/48x48/apps/gparted.png \
    /usr/share/icons/hicolor/scalable/apps/gparted.svg \
    /usr/share/pixmaps/gparted.xpm
do
    [[ -f "$candidate" ]] && { GPICON="$candidate"; break; }
done
[[ -z "$GPICON" ]] && GPICON="drive-harddisk"

# ── build drive list ──────────────────────────────────────────────────────────────

mapfile -t DRIVES < <(
    lsblk -dno NAME,TYPE,SIZE,TRAN,MODEL 2>/dev/null \
    | awk '$2=="disk" && $1!~/^sr/ {print $1, $3, $4, $5}'
)

if [[ ${#DRIVES[@]} -eq 0 ]]; then
    yad --center --title="$TITLE_ERR" \
        --image=dialog-warning \
        --text="$TEXT_NODEV" \
        --button="OK:0" 2>/dev/null
    exit 1
fi

# Build radiolist rows: TRUE/FALSE  LABEL  DEVICE_PATH
RADIO_LIST=()
first=true
for entry in "${DRIVES[@]}"; do
    read -r NAME SIZE TRAN MODEL <<< "$entry"

    case "$TRAN" in
        usb)  TRANSPORT="USB drive"    ;;
        nvme) TRANSPORT="NVMe drive"   ;;
        sata) TRANSPORT="SATA drive"   ;;
        ata)  TRANSPORT="ATA drive"    ;;
        mmc)  TRANSPORT="MMC/SD card"  ;;
        *)    TRANSPORT="disk"         ;;
    esac

    LABEL="${NAME}  [${TRANSPORT}]  ${SIZE}  ${MODEL}"

    if $first; then
        RADIO_LIST+=(TRUE "$LABEL" "/dev/$NAME")
        first=false
    else
        RADIO_LIST+=(FALSE "$LABEL" "/dev/$NAME")
    fi
done

# ── dialog ────────────────────────────────────────────────────────────────────────

CHOICE=$(
    yad --center \
        --title="$TITLE_DLG" \
        --window-icon="$GPICON" \
        --image="$GPICON" \
        --image-on-top \
        --text="$TEXT_DLG" \
        --list \
        --radiolist \
        --no-headers \
        --column=""          \
        --column="Drive"     \
        --column="Device":HD \
        --print-column=3     \
        --separator=$'\n'    \
        --width=560 --height=300 \
        --button="$BTN_CANCEL" \
        --button="$BTN_LAUNCH" \
        "${RADIO_LIST[@]}" 2>/dev/null
) || exit 0

CHOICE="$(grep -v '^$' <<< "$CHOICE" | head -1)"

[[ -z "$CHOICE" ]] && exit 0

# ── launch ────────────────────────────────────────────────────────────────────────

pkexec env DISPLAY="$DISPLAY" XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}" gparted "$CHOICE"
